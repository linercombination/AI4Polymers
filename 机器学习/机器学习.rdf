            <dcterms:URI>
                <rdf:value>https://dl.acm.org/doi/10.1145/3534678.3539347</rdf:value>
            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2025-08-21 15:34:47</dcterms:dateSubmitted>
        <bib:pages>1069-1078</bib:pages>
